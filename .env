# Copy this to .env and fill in your values
# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lms_ai
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=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
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_EMBEDDING_URL=https://openrouter.ai/api/v1/embeddings
LLM_MODEL=google/gemini-2.0-flash-001
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Context Engineering ─────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
RETRIEVAL_TOP_K=20
RERANKED_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
CACHE_QUERY_TTL_SECONDS=300
CONVERSATION_TTL_SECONDS=3600

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://semiexpositive-renaldo-unvindictively.ngrok-free.dev/
MOODLE_API_TOKEN=ec950af4e822b49599098282b95d308d
