# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=lms_ai
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# ─── Embedding (FastEmbed) ────────────────────────────────────────────────────
# Options: BAAI/bge-small-en-v1.5 (384-dim), BAAI/bge-base-en-v1.5 (768-dim)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=384

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct
LLM_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Context Engineering ─────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
RETRIEVAL_TOP_K=20
RERANKED_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
CACHE_QUERY_TTL_SECONDS=300
CONVERSATION_TTL_SECONDS=3600

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://microtutorcourses.org
MOODLE_API_TOKEN=
