# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=

# ─── Runtime / Infra (set in docker-compose, documented here) ────────────────
# Reduced to 8GB/2vCPU prod fit:
#  - api runs with `--workers 1` (single uvicorn worker).
#  - phoenix + pgadmin are opt-in: `docker compose --profile debug up`.
#  - redis is capped at 512mb (--maxmemory 512mb, allkeys-lru).
# OMP_NUM_THREADS / MKL_NUM_THREADS cap BLAS/onnxruntime intra-op threads to the
# 2 vCPUs so the fastembed BM25 sparse encoder doesn't oversubscribe cores
# (smooths P95). Set on the api + worker services in docker-compose.yml;
# override there if the VM gets more cores.
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
# Connection pool: base + overflow = max concurrent connections (10+20=30).
# pool_timeout = seconds a request waits for a free connection before failing
# fast (instead of SQLAlchemy's 30s default hang).
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=10

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=
REDIS_DB=0
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=
QDRANT_COLLECTION=

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=openai/text-embedding-3-small
EMBEDDING_DIM=1536

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY="" # 9Router key or empty if auth disabled
OPENROUTER_BASE_URL="http://localhost:20128/v1" # 9Router endpoint
# e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Context Engineering ─────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
RETRIEVAL_TOP_K=20
FINAL_TOP_K=6
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
# Query→answer cache lifetime. Governs BOTH the Redis exact-match cache AND the
# Qdrant semantic (paraphrase) cache. Long TTL = higher hit rate = fewer LLM
# calls. Safe: KB is stable, Moodle sync auto-invalidates affected entries, and
# expired entries are pruned (mem_limit caps RAM).
CACHE_QUERY_TTL_SECONDS=86400
# 24h — must outlive LTM_AFK_THRESHOLD_SECONDS so STM history+summary survive
# long enough for the AFK LTM worker to consume them.
CONVERSATION_TTL_SECONDS=86400
# AFK window before LTM sync fires. 10h matches "user closed laptop / went
# to sleep" rather than "stepped away for coffee".
LTM_AFK_THRESHOLD_SECONDS=36000

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://semiexpositive-renaldo-unvindictively.ngrok-free.dev/
MOODLE_API_TOKEN=

# ─── Phoenix (Observability — self-hosted Arize Phoenix) ─────────────────────
# NOTE: the phoenix service is now opt-in. It only starts with
#   docker compose --profile debug up
# The app tolerates it being down (setup_phoenix is wrapped in try/except), so
# api/worker boot fine without it — these vars just point at it when present.
PHOENIX_ENDPOINT=http://phoenix:6006
PHOENIX_OTLP_ENDPOINT=http://phoenix:4317
PHOENIX_PROJECT_NAME=ai-lms-agent

# ─── Retrieval gate ──────────────────────────────────────────────────────────
# Hybrid retrieval = dense (text-embedding-3-small) + sparse BM25, fused via
# relative-score fusion (VECTOR_WEIGHT = alpha on dense). The NOT-FOUND gate
# uses the RAW dense cosine top-1 (absolute [0,1]); below this, skip generate.
KB_MIN_DENSE_SCORE=0.30
# Lexical-match rescue: gate also passes if raw BM25 top-score clears this.
# Saves terse 1-word entity queries ("Modal", "CP") that score low on dense
# but match a KB term exactly. Off-scope queries have BM25=0.0 so stay blocked.
KB_MIN_SPARSE_SCORE=1.0

# ─── Evaluation (LLM-as-judge, async via arq) ────────────────────────────────
# Phase 1: post-hoc faithfulness eval. Uses get_cheap_llm (Gemini Flash Lite),
# annotates Phoenix span with `eval_faithfulness` score.
# Sample rate keeps cost negligible; always-eval gates catch high-stakes turns.
EVAL_ENABLED=true
EVAL_SAMPLE_RATE=0.10
EVAL_ALWAYS_IF_DENSE_BELOW=0.30
EVAL_ALWAYS_IF_EMPATHY_ABOVE=0.90

# ─── Askfer (Portfolio Chat) ─────────────────────────────────────────────────
# Public chat endpoint for ferdy-fadhil-lazuardi.my.id portfolio.
# Generate a long random secret (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
ASKFER_ADMIN_SECRET=
