# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=
REDIS_DB=0
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=
QDRANT_COLLECTION=

# ─── Embedding ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY="" # 9Router key or empty if auth disabled
OPENROUTER_BASE_URL="http://localhost:20128/v1" # 9Router endpoint
OLLAMA_BASE_URL=http://172.16.10.2:11434/v1
# e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct
LLM_MODEL=google/gemini-2.5-flash-lite
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Context Engineering ─────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
RETRIEVAL_TOP_K=15
RERANKED_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
CACHE_QUERY_TTL_SECONDS=1800
CONVERSATION_TTL_SECONDS=3600

# ─── Follow-up validation ────────────────────────────────────────────────────
# Embed each suggested follow-up and check Qdrant top-1 similarity.
# Drop follow-ups with similarity below threshold to avoid dead-end suggestions.
FOLLOWUP_VALIDATION_ENABLED=true
FOLLOWUP_VALIDATION_THRESHOLD=0.5

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://semiexpositive-renaldo-unvindictively.ngrok-free.dev/
MOODLE_API_TOKEN=

# ─── Langfuse (Observability) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ─── Askfer (Portfolio Chat) ─────────────────────────────────────────────────
# Public chat endpoint for ferdy-fadhil-lazuardi.my.id portfolio.
# Generate a long random secret (e.g. `python -c "import secrets;print(secrets.token_urlsafe(32))"`).
ASKFER_ADMIN_SECRET=
