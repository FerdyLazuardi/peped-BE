# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=
REDIS_DB=0
REDIS_PASSWORD=

# ─── Qdrant ───────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=
QDRANT_COLLECTION=

# ─── Embedding (FastEmbed) ────────────────────────────────────────────────────
# Options: BAAI/bge-small-en-v1.5 (384-dim), BAAI/bge-base-en-v1.5 (768-dim)
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIM=

# ─── OpenRouter LLM ──────────────────────────────────────────────────────────
OPENROUTER_API_KEY="" # 9Router key or empty if auth disabled
OPENROUTER_BASE_URL="http://localhost:20128/v1" # 9Router endpoint
OLLAMA_BASE_URL=http://172.16.10.2:11434/v1
# e.g. openai/gpt-4o-mini, anthropic/claude-3-haiku, mistralai/mistral-7b-instruct
LLM_MODEL=qwen2.5:1.5b
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=2048

# ─── Context Engineering ─────────────────────────────────────────────────────
MAX_CONTEXT_TOKENS=6000
RETRIEVAL_TOP_K=20
RERANKED_TOP_K=5
BM25_WEIGHT=0.3
VECTOR_WEIGHT=0.7

# ─── Cache / Memory TTL ──────────────────────────────────────────────────────
CACHE_QUERY_TTL_SECONDS=300
CONVERSATION_TTL_SECONDS=3600

# ─── Moodle LMS ──────────────────────────────────────────────────────────────
MOODLE_API_URL=https://semiexpositive-renaldo-unvindictively.ngrok-free.dev/
MOODLE_API_TOKEN=

# ─── Langfuse (Observability) ────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
